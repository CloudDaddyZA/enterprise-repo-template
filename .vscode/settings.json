{
  "editor.formatOnSave": true,
  "editor.rulers": [
    100
  ],
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "editor.tabSize": 2,
  "editor.detectIndentation": true,
  "files.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/.terraform": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/.terraform": true
  }
}
